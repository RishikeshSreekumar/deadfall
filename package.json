{
  "name": "deadfall",
  "version": "0.2.0",
  "description": "Dev tool to map React/Next.js component usage and dead components as a static graph.",
  "license": "MIT",
  "author": "Rishikesh S",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RishikeshSreekumar/deadfall.git"
  },
  "homepage": "https://github.com/RishikeshSreekumar/deadfall#readme",
  "bugs": {
    "url": "https://github.com/RishikeshSreekumar/deadfall/issues"
  },
  "keywords": [
    "react",
    "nextjs",
    "next",
    "dead-code",
    "dead-components",
    "unused",
    "component-graph",
    "static-analysis",
    "ts-morph",
    "typescript",
    "cli",
    "app-router",
    "dependency-graph",
    "visualization"
  ],
  "type": "module",
  "bin": {
    "deadfall": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/build-client.mjs",
    "build:client": "node scripts/build-client.mjs",
    "typecheck:client": "tsc -p tsconfig.client.json",
    "dev": "tsc -p tsconfig.json --watch",
    "start": "node dist/cli.js",
    "pretest": "node scripts/build-client.mjs",
    "test": "node --test --import tsx test/*.test.ts",
    "prepare": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "cytoscape": "^3.30.2",
    "globby": "^14.0.2",
    "ts-morph": "^23.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.28.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
