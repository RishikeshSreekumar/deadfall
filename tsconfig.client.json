{
  // Type-check only (esbuild does the transpile). The browser client targets the
  // DOM and is excluded from the main Node build in tsconfig.json.
  "compilerOptions": {
    "target": "ES2017",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2017", "DOM", "DOM.Iterable"],
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/report/client"]
}
